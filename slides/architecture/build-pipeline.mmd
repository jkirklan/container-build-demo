    classDef rhhi fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    classDef security fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef deploy fill:#fce4ec,stroke:#c2185b,stroke-width:2px

    class Start,PreCommit,Trigger,Verify startEnd
    class BuildUBI,SecretUBI,ScanUBI,SBOMU,PushUBI ubi
    class BuildRHHI,SecretRHHI,ScanRHHI,SBOMR,PushRHHI rhhi
